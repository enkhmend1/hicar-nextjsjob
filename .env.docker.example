# Copy to .env (in project root) — used by docker-compose
# Required
JWT_SECRET=replace-with-long-random-secret-32+chars
REFRESH_TOKEN_SECRET=replace-with-different-long-random-secret-32+chars

# Frontend URL the backend will trust (CORS)
CLIENT_ORIGIN=http://localhost:3000
# Backend URL the frontend will call
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# JWT lifetimes
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
COOKIE_DOMAIN=

# First-user-auto-admin: only this email gets auto-promoted
BOOTSTRAP_ADMIN_EMAIL=admin@hicar.mn

# Optional integrations — leave blank to disable
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hicar

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# QPay (https://merchant.qpay.mn)
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_CALLBACK_URL=https://YOUR_PUBLIC_DOMAIN/api/qpay/callback
QPAY_BASE_URL=https://merchant.qpay.mn/v2

# Email (SMTP) for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@hicar.mn

# Cache TTL for product list / dashboard
CACHE_TTL_SECONDS=60
