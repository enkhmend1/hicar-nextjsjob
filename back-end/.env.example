# HiCar back-end environment — copy to `.env` and fill in real values.
# `.env` itself is git-ignored; never commit real secrets.
# All integrations degrade gracefully if left blank (see CLAUDE.md).

# ── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development          # set to "production" on the live server
PORT=5001
MONGO_URI=mongodb://localhost:27017/hicar
CLIENT_ORIGIN=http://localhost:3000   # front-end origin (CORS + cookies)
COOKIE_DOMAIN=                # e.g. .hicar.mn in production, blank in dev
LOG_LEVEL=                    # debug|info|warn|error (default: debug dev / info prod)

# ── Auth / tokens ─────────────────────────────────────────────────────
JWT_SECRET=                   # long random string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=         # long random string, DIFFERENT from JWT_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Cache / queues (Redis) ────────────────────────────────────────────
# Required in production (rate limiting, BullMQ, QPay replay guard).
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60

# ── Payments: QPay v2 (https://developer.qpay.mn) ─────────────────────
# Without USERNAME/PASSWORD/INVOICE_CODE the whole /api/qpay surface is
# disabled (returns 503) — the app still boots.
QPAY_USERNAME=                # merchant username
QPAY_PASSWORD=                # merchant password
QPAY_INVOICE_CODE=            # merchant invoice template code
QPAY_BASE_URL=https://merchant.qpay.mn/v2
# Public URL QPay POSTs to on payment. Needs a deployed HTTPS host; polling
# works without it but the callback is more reliable. Register the same URL
# (WITH the secret) in the QPay merchant dashboard.
QPAY_CALLBACK_URL=            # e.g. https://api.hicar.mn/api/qpay/callback
# REQUIRED in production: without it the callback is rejected (503). Generate
# a fresh one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
QPAY_CALLBACK_SECRET=
QPAY_REPLAY_WINDOW_S=10       # callback de-dupe window (optional)

# ── Media: Cloudinary (falls back to local /uploads if unset) ─────────
CLOUDINARY_CLOUD_NAME=        # 3-30 lowercase letters/digits/hyphens
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hicar

# ── Email: SMTP (falls back to console logging if unset) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@hicar.mn

# ── AI providers (all optional; chat degrades to the next in the chain) ─
ANTHROPIC_API_KEY=            # primary chat brain
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
GROQ_API_KEY=                 # fast text fallback
GROQ_BASE_URL=
GROQ_MODEL=
GEMINI_API_KEY=               # vision
GEMINI_BASE_URL=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
AI_REQUEST_TIMEOUT_MS=30000
AI_REQUEST_MAX_RETRIES=4

# ── Vehicle plate lookup (Garage provider) ────────────────────────────
GARAGE_API_URL=
GARAGE_API_KEY=
GARAGE_TIMEOUT_MS=8000
GARAGE_MAX_RETRIES=2
GARAGE_CACHE_TTL=86400

# ── Scraping proxy pool (optional; direct-connect if empty) ───────────
PROXY_URLS=                   # comma-separated proxy endpoints

# ── Data platform (TypeScript service under src/data-platform) ─────────
DP_PORT=5100
DP_AI_MODEL=
DP_AI_ENRICH=                 # "true" to let AI fill unresolved fields
DP_SEARCH=                    # "true" to enable Typesense-backed search
TYPESENSE_HOST=
TYPESENSE_PORT=
TYPESENSE_PROTOCOL=
TYPESENSE_API_KEY=
TYPESENSE_COLLECTION=
